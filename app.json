{
  "expo": {
    "name": "POS PowerPlay",
    "slug": "pos-powerplay",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "pospowerplay",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pospowerplay.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Digunakan untuk scan barcode produk",
        "NSPhotoLibraryUsageDescription": "Digunakan untuk menyimpan gambar barcode"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6C63FF"
      },
      "package": "com.pospowerplay.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "POS PowerPlay memerlukan akses kamera untuk scan barcode produk."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
